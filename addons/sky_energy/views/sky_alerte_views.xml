<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Vue liste -->
        <record id="view_sky_alerte_tree" model="ir.ui.view">
            <field name="name">sky.alerte.tree</field>
            <field name="model">sky.alerte</field>
            <field name="arch" type="xml">
                <list string="Alertes" decoration-danger="severity == 'critical'" decoration-warning="severity == 'high'" decoration-info="severity == 'medium'" decoration-muted="state in ('resolved', 'cancelled')">
                    <field name="name"/>
                    <field name="installation_id"/>
                    <field name="type_alerte"/>
                    <field name="date_alerte"/>
                    <field name="severity" widget="badge"/>
                    <field name="state" widget="badge"/>
                    <field name="intervention_id"/>
                </list>
            </field>
        </record>

        <!-- Vue formulaire -->
        <record id="view_sky_alerte_form" model="ir.ui.view">
            <field name="name">sky.alerte.form</field>
            <field name="model">sky.alerte</field>
            <field name="arch" type="xml">
                <form string="Alerte Métier">
                    <header>
                        <button name="action_in_progress" string="Prendre en charge" type="object" class="btn-warning" invisible="state != 'open'"/>
                        <button name="action_create_intervention" string="Créer une intervention" type="object" class="btn-primary" invisible="state not in ('open', 'in_progress')"/>
                        <button name="action_resolve" string="Résoudre" type="object" class="btn-success" invisible="state not in ('open', 'in_progress')"/>
                        <button name="action_cancel" string="Annuler" type="object" invisible="state in ('resolved', 'cancelled')"/>
                        <field name="state" widget="statusbar" statusbar_visible="open,in_progress,resolved"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <label for="name"/>
                            <h1>
                                <field name="name" readonly="1"/>
                            </h1>
                        </div>
                        <group>
                            <group string="Informations de l'alerte">
                                <field name="installation_id"/>
                                <field name="type_alerte"/>
                                <field name="date_alerte"/>
                            </group>
                            <group string="Criticité et suivi">
                                <field name="severity"/>
                                <field name="intervention_id"/>
                            </group>
                        </group>
                        <group string="Description">
                            <field name="description" nolabel="1" colspan="2" placeholder="Décrivez l'alerte..."/>
                        </group>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <!-- Action window -->
        <record id="action_sky_alerte" model="ir.actions.act_window">
            <field name="name">Alertes</field>
            <field name="res_model">sky.alerte</field>
            <field name="view_mode">list,form</field>
            <field name="context">{'search_default_open': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Aucune alerte active. Bonne nouvelle !
                </p>
            </field>
        </record>

    </data>
</odoo>
