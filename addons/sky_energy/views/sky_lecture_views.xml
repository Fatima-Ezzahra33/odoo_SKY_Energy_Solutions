<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Vue liste -->
        <record id="view_sky_lecture_tree" model="ir.ui.view">
            <field name="name">sky.lecture.tree</field>
            <field name="model">sky.lecture</field>
            <field name="arch" type="xml">
                <list string="Lectures énergétiques">
                    <field name="name"/>
                    <field name="installation_id"/>
                    <field name="capteur_id"/>
                    <field name="date_lecture"/>
                    <field name="energie_kwh"/>
                    <field name="puissance_instantanee"/>
                    <field name="irradiation"/>
                    <field name="temperature"/>
                    <field name="source" widget="badge"/>
                </list>
            </field>
        </record>

        <!-- Vue formulaire -->
        <record id="view_sky_lecture_form" model="ir.ui.view">
            <field name="name">sky.lecture.form</field>
            <field name="model">sky.lecture</field>
            <field name="arch" type="xml">
                <form string="Lecture Énergétique">
                    <sheet>
                        <div class="oe_title">
                            <label for="name"/>
                            <h1>
                                <field name="name" placeholder="Référence lecture"/>
                            </h1>
                        </div>
                        <group>
                            <group string="Source de la lecture">
                                <field name="installation_id"/>
                                <field name="capteur_id" domain="[('installation_id', '=', installation_id)]"/>
                                <field name="date_lecture"/>
                                <field name="source"/>
                            </group>
                            <group string="Valeurs mesurées">
                                <field name="energie_kwh"/>
                                <field name="puissance_instantanee"/>
                                <field name="irradiation"/>
                                <field name="temperature"/>
                            </group>
                        </group>
                        <group string="Notes">
                            <field name="notes" nolabel="1" colspan="2"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Action window -->
        <record id="action_sky_lecture" model="ir.actions.act_window">
            <field name="name">Lectures énergétiques</field>
            <field name="res_model">sky.lecture</field>
            <field name="view_mode">list,form</field>
            <field name="context">{'search_default_group_installation': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Enregistrez votre première lecture énergétique !
                </p>
            </field>
        </record>

    </data>
</odoo>
