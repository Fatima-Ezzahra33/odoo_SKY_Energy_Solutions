<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Vue liste -->
        <record id="view_sky_intervention_tree" model="ir.ui.view">
            <field name="name">sky.intervention.tree</field>
            <field name="model">sky.intervention</field>
            <field name="arch" type="xml">
                <list string="Interventions" decoration-success="state == 'done'" decoration-info="state == 'planned'" decoration-muted="state == 'cancelled'">
                    <field name="name"/>
                    <field name="installation_id"/>
                    <field name="type_intervention"/>
                    <field name="technicien_id"/>
                    <field name="date_planifiee"/>
                    <field name="date_realisation"/>
                    <field name="state" widget="badge"/>
                </list>
            </field>
        </record>

        <!-- Vue formulaire -->
        <record id="view_sky_intervention_form" model="ir.ui.view">
            <field name="name">sky.intervention.form</field>
            <field name="model">sky.intervention</field>
            <field name="arch" type="xml">
                <form string="Intervention Terrain">
                    <header>
                        <button name="action_plan" string="Planifier" type="object" class="btn-primary" invisible="state != 'draft'"/>
                        <button name="action_done" string="Marquer réalisée" type="object" class="btn-success" invisible="state != 'planned'"/>
                        <button name="action_cancel" string="Annuler" type="object" invisible="state in ('done', 'cancelled')"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,planned,done"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <label for="name"/>
                            <h1>
                                <field name="name" readonly="1"/>
                            </h1>
                        </div>
                        <group>
                            <group string="Informations générales">
                                <field name="installation_id"/>
                                <field name="alerte_id" domain="[('installation_id', '=', installation_id)]"/>
                                <field name="type_intervention"/>
                            </group>
                            <group string="Planification">
                                <field name="technicien_id"/>
                                <field name="date_planifiee"/>
                                <field name="date_realisation" readonly="1"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Description" name="description">
                                <field name="description" placeholder="Décrivez l'intervention à effectuer..."/>
                            </page>
                            <page string="Solution appliquée" name="solution">
                                <field name="solution" placeholder="Décrivez la solution apportée..."/>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <!-- Action window -->
        <record id="action_sky_intervention" model="ir.actions.act_window">
            <field name="name">Interventions</field>
            <field name="res_model">sky.intervention</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Planifiez votre première intervention terrain !
                </p>
            </field>
        </record>

    </data>
</odoo>
